# ──────────────────────────────────────────────
# GeoAgent Configuration
# Copy this file to .env and fill in your keys
# ──────────────────────────────────────────────

# ── Required ──
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: External Verification Tools ──
# These enable "full" analysis mode with external verification
GOOGLE_MAPS_API_KEY=AIza...
SERPAPI_KEY=...

# ── Optional: Webhook Mode ──
# Leave empty to use polling (default, recommended for local dev)
TELEGRAM_WEBHOOK_URL=

# ── Advanced (defaults are fine for most users) ──
# MODEL_HEAVY=claude-sonnet-4-20250514
# MODEL_LIGHT=claude-haiku-4-5-20251001
# THINKING_BUDGET=10000
# PIPELINE_TIMEOUT=300
# RATE_LIMIT_PER_HOUR=10
# MAX_IMAGE_SIZE=2048
